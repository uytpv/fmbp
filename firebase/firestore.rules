rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Kiểm tra người dùng đã đăng nhập
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Kiểm tra tài khoản truy cập chính là chủ sở hữu tài nguyên
    function isSelf(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Rules cho Users collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated() && isSelf(userId);
    }

    // Rules cho Families collection & tất cả sub-collections (members, pantry_items, budgets, meal_plans, shopping_lists)
    match /families/{familyId} {
      allow read, create, update, delete: if isAuthenticated();

      match /{allSubcollections=**} {
        allow read, write: if isAuthenticated();
      }
    }

    // Rules cho Recipes (có thể public hoặc private)
    match /recipes/{recipeId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated();
    }

    // Rules cho Ingredients (chung cho toàn hệ thống)
    match /ingredients/{ingredientId} {
      allow read, write: if isAuthenticated();
    }
  }
}
